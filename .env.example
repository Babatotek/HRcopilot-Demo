# ─── HR360 API Keys ───────────────────────────────────────────────────────────

# Groq — Primary LLM + TTS engine
# Add up to 5 keys — system auto-rotates on rate-limit (429)
VITE_GROQ_API_KEY=gsk_your_key_here
# VITE_GROQ_API_KEY_2=gsk_your_second_key_here
# VITE_GROQ_API_KEY_3=gsk_your_third_key_here
# VITE_GROQ_API_KEY_4=gsk_your_fourth_key_here
# VITE_GROQ_API_KEY_5=gsk_your_fifth_key_here

# ElevenLabs — Neural voice synthesis (optional)
# Add up to 10 accounts — each with its own API key + voice ID
VITE_ELEVENLABS_API_KEY=sk_your_key_here
VITE_ELEVENLABS_VOICE_ID=your_voice_id_here
# VITE_ELEVENLABS_API_KEY_2=sk_...
# VITE_ELEVENLABS_VOICE_ID_2=...
# VITE_ELEVENLABS_API_KEY_3=sk_...
# VITE_ELEVENLABS_VOICE_ID_3=...
# (up to _10)

# Demo mode flag
VITE_DEMO_MODE=true
